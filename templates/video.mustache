<div class="mod-videoplayer-container mod-videoplayer-native" data-resource-type="{{type}}" data-cmid="{{cmid}}"{{#playerstyle}} style="{{playerstyle}}"{{/playerstyle}}>
    <div class="mod-videoplayer-meta mb-2">
        <span class="mod-videoplayer-meta-item">{{resourcetype}}</span>
        <span class="mod-videoplayer-meta-item">{{#str}} protectedresource, mod_videoplayer {{/str}}</span>
    </div>

    <div class="mod-videoplayer-native-frame" oncontextmenu="return false;">
        <video
            class="mod-videoplayer-native-video js-drive-resource-video"
            controls
            controlslist="nodownload"
            disablepictureinpicture
            draggable="false"
            oncontextmenu="return false;"
            playsinline
            webkit-playsinline
            preload="auto"
            title="{{title}}">
            <source src="{{videourl}}" type="video/mp4">
            {{#str}} videonotsupported, mod_videoplayer {{/str}}
        </video>
    </div>
</div>
