<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="mod/videoplayer/db" VERSION="20260614" COMMENT="XMLDB file for Moodle mod_videoplayer"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>

    <TABLE NAME="videoplayer" COMMENT="Stores Google Drive resource activity module instances.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="course" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="intro" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="introformat" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="source" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="googledrive"/>
        <FIELD NAME="videourl" TYPE="char" LENGTH="1024" NOTNULL="true"/>
        <FIELD NAME="type" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="auto"/>
        <FIELD NAME="video" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="endscreentext" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="displayasstartscreen" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="starttime" TYPE="number" LENGTH="10" NOTNULL="false" DECIMALS="2"/>
        <FIELD NAME="endtime" TYPE="number" LENGTH="10" NOTNULL="false" DECIMALS="2"/>
        <FIELD NAME="completionpercentage" TYPE="int" LENGTH="3" NOTNULL="true" DEFAULT="80"/>
        <FIELD NAME="grade" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="displayoptions" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="posterimage" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="extendedcompletion" TYPE="text" NOTNULL="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_course" TYPE="foreign" FIELDS="course" REFTABLE="course" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="course_idx" UNIQUE="false" FIELDS="course"/>
        <INDEX NAME="source_idx" UNIQUE="false" FIELDS="source"/>
        <INDEX NAME="type_idx" UNIQUE="false" FIELDS="type"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="videoplayer_views" COMMENT="Tracks Google Drive resource views and progress per user.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="videoplayerid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="progress" TYPE="number" LENGTH="10" NOTNULL="true" DEFAULT="0" DECIMALS="2"/>
        <FIELD NAME="completed" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="completionpercentage" TYPE="number" LENGTH="5" NOTNULL="true" DEFAULT="0" DECIMALS="2"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_videoplayerid" TYPE="foreign" FIELDS="videoplayerid" REFTABLE="videoplayer" REFFIELDS="id"/>
        <KEY NAME="fk_userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="uniq_videoplayer_user" TYPE="unique" FIELDS="videoplayerid, userid"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="videoplayerid_idx" UNIQUE="false" FIELDS="videoplayerid"/>
        <INDEX NAME="userid_idx" UNIQUE="false" FIELDS="userid"/>
        <INDEX NAME="completed_idx" UNIQUE="false" FIELDS="completed"/>
        <INDEX NAME="timemodified_idx" UNIQUE="false" FIELDS="timemodified"/>
      </INDEXES>
    </TABLE>

  </TABLES>
</XMLDB>
